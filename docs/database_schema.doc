<h1>Database Schema (Backend Models)</h1>
<p>Generated from TypeORM entities in <i>src/graphql/models/</i>.</p>

<div class='tbl-title'>ຕາຕະລາງ users</div>
<table>
<tr><th>Field Name</th><th>Data Type</th><th>Size</th><th>Key</th><th>Reference</th><th>Description</th></tr>
<tr><td>id</td><td>UUID</td><td>-</td><td>PK</td><td></td><td>Primary key (auto)</td></tr>
<tr><td>firstName</td><td>VARCHAR</td><td>50</td><td></td><td></td><td>User first name</td></tr>
<tr><td>lastName</td><td>VARCHAR</td><td>50</td><td></td><td></td><td>User last name</td></tr>
<tr><td>password</td><td>VARCHAR</td><td>255</td><td></td><td></td><td>Hashed password</td></tr>
<tr><td>phoneNumber</td><td>VARCHAR</td><td>20</td><td>UNIQUE</td><td></td><td>Login phone (unique)</td></tr>
<tr><td>email</td><td>VARCHAR</td><td>100</td><td>UNIQUE</td><td></td><td>Email (optional, unique)</td></tr>
<tr><td>profileImageUrl</td><td>TEXT</td><td>-</td><td></td><td></td><td>Profile picture URL</td></tr>
<tr><td>shopName</td><td>VARCHAR</td><td>100</td><td></td><td></td><td>Shop name (for shop owners)</td></tr>
<tr><td>bankAccountImageUrl</td><td>TEXT</td><td>-</td><td></td><td></td><td>Bank account / QR image</td></tr>
<tr><td>role</td><td>VARCHAR</td><td>20</td><td></td><td></td><td>admin / manager / staff (default: staff)</td></tr>
<tr><td>status</td><td>ENUM</td><td>-</td><td></td><td></td><td>ACTIVE / INACTIVE</td></tr>
<tr><td>otp</td><td>VARCHAR</td><td>6</td><td></td><td></td><td>OTP code for verification</td></tr>
<tr><td>otpExpiry</td><td>TIMESTAMP</td><td>-</td><td></td><td></td><td>OTP expiry time</td></tr>
<tr><td>createdAt</td><td>TIMESTAMP</td><td>-</td><td></td><td></td><td>Record created time</td></tr>
<tr><td>updatedAt</td><td>TIMESTAMP</td><td>-</td><td></td><td></td><td>Record last updated</td></tr>
</table>

