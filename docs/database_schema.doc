<tr><th>Field Name</th><th>Data Type</th><th>Size</th><th>Key</th><th>Reference</th><th>Description</th></tr>
<tr><td>id</td><td>UUID</td><td>-</td><td>PK</td><td></td><td>Primary key</td></tr>
<tr><td>saleId</td><td>UUID</td><td>-</td><td>FK</td><td>sales.id</td><td>Sale being paid</td></tr>
<tr><td>paymentMethod</td><td>VARCHAR</td><td>50</td><td></td><td></td><td>cash / transfer / etc.</td></tr>
<tr><td>currency</td><td>VARCHAR</td><td>10</td><td></td><td></td><td>KIP / THB / USD</td></tr>
<tr><td>amount</td><td>DECIMAL</td><td>12,2</td><td></td><td></td><td>Payment amount</td></tr>
<tr><td>slipImageUrl</td><td>TEXT</td><td>-</td><td></td><td></td><td>Transfer slip image</td></tr>
<tr><td>paidAt</td><td>TIMESTAMP</td><td>-</td><td></td><td></td><td>Paid time</td></tr>
</table>

<div class='tbl-title'>ຕາຕະລາງ deliveries</div>
