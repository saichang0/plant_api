{
    "name": "plant_api",
    "version": "1.0.0",
    "description": "Plant API with Apollo Server, Express and TypeORM",
    "type": "module",
    "main": "dist/server.js",
    "scripts": {
        "dev": "nodemon --watch src --ext ts --exec \"tsx src/server.ts\"",
        "build": "tsc",
        "start": "node dist/server.js",
        "typeorm": "typeorm-ts-node-esm"
    },
    "dependencies": {
        "@apollo/server": "^4.9.5",
        "bcrypt": "^6.0.0",
        "cloudinary": "^2.8.0",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^4.18.2",
        "graphql": "^16.8.1",
        "graphql-tag": "^2.12.6",
        "jsonwebtoken": "^9.0.2",
        "mongodb": "^5.9.1",
        "multer": "^2.0.2",
        "nodemailer": "^7.0.9",
        "pg": "^8.20.0",
        "reflect-metadata": "^0.2.2",
        "typeorm": "^0.3.17"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/cors": "^2.8.13",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.0.0",
        "@types/node": "^24.9.2",
        "@types/nodemailer": "^7.0.2",
        "@types/uuid": "^10.0.0",
        "cross-env": "^10.1.0",
        "nodemon": "^3.1.10",
        "ts-node": "^10.9.2",
        "tsx": "^4.20.6",
        "typeorm-extension": "^3.6.0",
        "typescript": "^5.9.3"
